print("=== String Input Örnekleri ===")

set name = input<str>("Adınız nedir?")
print("Merhaba, ")
print(name)

set surname = input<str>("Soyadınız nedir?")
print("Tam ad: ")
print(name)
print(" ")
print(surname)

set city = input<str>("Şehriniz?")
print("Şehir: ")
print(city)

set color = input<str>("En sevdiğiniz renk?")
print("Sevdiğiniz renk: ")
print(color)

set description = input<str>("Açıklama yazın:")
print("Yazdığınız: ")
print(description)
