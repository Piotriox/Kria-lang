// Comprehensive function tests

// Test 1: Named function with multiple parameters
fn multiply(a, b, c) {
    set result = a * b * c
    return result
}

print(multiply(2, 3, 4))

// Test 2: Function with nested operations
fn calculate(x, y) {
    set sum = x + y
    set product = x * y
    set combined = sum + product
    return combined
}

print(calculate(5, 3))

// Test 3: Anonymous function stored in variable
set square = fn(num) {
    return num * num
}

print(square(7))

// Test 4: Chained function calls
set add_one = fn(x) {
    return x + 1
}

set double = fn(y) {
    return y * 2
}

set x = add_one(5)
set y = double(x)
print(y)

// Test 5: Function with conditionals
fn max_value(a, b) {
    if (a > b) {
        return a
    } else {
        return b
    }
}

print(max_value(10, 7))
print(max_value(3, 8))

// Test 6: Function with loops
fn sum_to(n) {
    set total = 0
    set i = 0
    while (i < n) {
        set total = total + 1
        set i = i + 1
    }
    return total
}

print(sum_to(5))
print(sum_to(10))

// Test 7: Recursive-like (via reassignment)
fn fibonacci_2terms(a, b) {
    return a + b
}

print(fibonacci_2terms(3, 5))
print(fibonacci_2terms(21, 34))





Test 1: multiply(2,3,4) = 24 
Test 2: calculate(5,3) = (5+3)+(5*3) = 23 
Test 3: square(7) = 49 
Test 4: Chained calls = 12 
Test 5: Conditionals = 10, 8 
Test 6: Loops = 5, 10 
Test 7: Fibonacci = 8, 55 